# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log

# Exclude override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan files
*.tfplan

# Sensitive variable files
*.tfvars
*.tfvars.json

# Ignore CLI configuration files
.terraformrc
terraform.rc


google-cloud-sdk/
